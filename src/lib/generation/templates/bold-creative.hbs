<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{name}} - Portfolio</title>
  <style>
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    :root {
      --color-primary: #ff6b35;
      --color-secondary: #004e89;
      --color-accent: #ffd166;
      --color-bg: #0a0a0a;
      --color-surface: #141414;
      --color-text: #f0f0f0;
      --color-text-muted: #9ca3af;
      --font-display: 'Georgia', serif;
      --font-body: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      --max-width: 1100px;
    }
    body {
      font-family: var(--font-body);
      background: var(--color-bg);
      color: var(--color-text);
      line-height: 1.6;
      font-size: 16px;
    }
    .container {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 32px;
    }
    .hero {
      min-height: 80vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 80px 0;
    }
    .hero h1 {
      font-family: var(--font-display);
      font-size: 4.5rem;
      font-weight: 700;
      line-height: 1.05;
      margin-bottom: 20px;
      background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero .headline {
      font-size: 1.4rem;
      color: var(--color-text-muted);
      max-width: 600px;
    }
    section {
      padding: 80px 0;
    }
    section h2 {
      font-family: var(--font-display);
      font-size: 2.2rem;
      font-weight: 700;
      margin-bottom: 40px;
      color: var(--color-primary);
    }
    .bio p {
      font-size: 1.15rem;
      color: var(--color-text);
      max-width: 700px;
      line-height: 1.8;
    }
    .experience-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 24px;
    }
    .experience-card {
      background: var(--color-surface);
      border-radius: 16px;
      padding: 32px;
      border: 1px solid rgba(255,255,255,0.06);
      transition: border-color 0.2s;
    }
    .experience-card:hover {
      border-color: var(--color-primary);
    }
    .experience-card h3 {
      font-size: 1.15rem;
      font-weight: 600;
      margin-bottom: 4px;
    }
    .experience-card .meta {
      font-size: 0.85rem;
      color: var(--color-text-muted);
      margin-bottom: 12px;
    }
    .experience-card p {
      font-size: 0.95rem;
      color: var(--color-text-muted);
      line-height: 1.6;
    }
    .education-item {
      margin-bottom: 24px;
      padding-left: 20px;
      border-left: 3px solid var(--color-primary);
    }
    .education-item h3 {
      font-size: 1.1rem;
      font-weight: 600;
    }
    .education-item .meta {
      font-size: 0.9rem;
      color: var(--color-text-muted);
    }
    .skills-cloud {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }
    .skill-badge {
      display: inline-block;
      padding: 8px 20px;
      background: var(--color-surface);
      color: var(--color-accent);
      border: 1px solid rgba(255,209,102,0.2);
      border-radius: 100px;
      font-size: 0.9rem;
      font-weight: 500;
      transition: background 0.2s, border-color 0.2s;
    }
    .skill-badge:hover {
      background: rgba(255,209,102,0.1);
      border-color: var(--color-accent);
    }
    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 24px;
    }
    .project-card {
      background: var(--color-surface);
      border-radius: 16px;
      padding: 32px;
      border: 1px solid rgba(255,255,255,0.06);
    }
    .project-card h3 {
      font-size: 1.15rem;
      font-weight: 600;
      margin-bottom: 8px;
    }
    .project-card p {
      font-size: 0.95rem;
      color: var(--color-text-muted);
      margin-bottom: 12px;
    }
    .project-card .tech {
      font-size: 0.8rem;
      color: var(--color-primary);
      margin-bottom: 12px;
    }
    .project-card a {
      color: var(--color-accent);
      text-decoration: none;
      font-weight: 500;
      font-size: 0.9rem;
    }
    .project-card a:hover {
      text-decoration: underline;
    }
    .links-list {
      list-style: none;
      display: flex;
      gap: 32px;
    }
    .links-list a {
      color: var(--color-text);
      text-decoration: none;
      font-weight: 600;
      font-size: 1.05rem;
      transition: color 0.2s;
    }
    .links-list a:hover {
      color: var(--color-primary);
    }
    @media (max-width: 640px) {
      .hero h1 { font-size: 2.5rem; }
      .hero { min-height: 60vh; padding: 48px 0; }
      .container { padding: 0 20px; }
      section { padding: 48px 0; }
      .experience-grid, .projects-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="container">
    <header class="hero">
      <h1>{{name}}</h1>
      <p class="headline">{{headline}}</p>
    </header>

    <section class="bio">
      <h2>About</h2>
      <p>{{bio}}</p>
    </section>

    {{#if experience.length}}
    <section>
      <h2>Experience</h2>
      <div class="experience-grid">
        {{#each experience}}
        <div class="experience-card">
          <h3>{{this.title}}</h3>
          <div class="meta">{{this.company}} &middot; {{formatDate this.startDate}} &ndash; {{formatDate this.endDate}}</div>
          <p>{{this.description}}</p>
        </div>
        {{/each}}
      </div>
    </section>
    {{/if}}

    {{#if education.length}}
    <section>
      <h2>Education</h2>
      {{#each education}}
      <div class="education-item">
        <h3>{{this.institution}}</h3>
        <div class="meta">{{this.degree}} in {{this.field}} &middot; {{formatDate this.graduationDate}}</div>
      </div>
      {{/each}}
    </section>
    {{/if}}

    {{#if skills.length}}
    <section>
      <h2>Skills</h2>
      <div class="skills-cloud">
        {{#each skills}}
        {{{skillBadge this}}}
        {{/each}}
      </div>
    </section>
    {{/if}}

    {{#if projects.length}}
    <section>
      <h2>Projects</h2>
      <div class="projects-grid">
        {{#each projects}}
        <div class="project-card">
          <h3>{{this.name}}</h3>
          <p>{{this.description}}</p>
          <div class="tech">{{#each this.technologies}}{{this}}{{#unless @last}} / {{/unless}}{{/each}}</div>
          {{#if this.url}}
          <a href="{{this.url}}" target="_blank" rel="noopener noreferrer">View project</a>
          {{/if}}
        </div>
        {{/each}}
      </div>
    </section>
    {{/if}}

    {{#if links.length}}
    <section>
      <h2>Links</h2>
      <ul class="links-list">
        {{#each links}}
        <li>{{{externalLink this.url this.label}}}</li>
        {{/each}}
      </ul>
    </section>
    {{/if}}
  </div>
</body>
</html>
