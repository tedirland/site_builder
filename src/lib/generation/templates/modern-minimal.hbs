<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{name}} - Portfolio</title>
  <style>
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    :root {
      --color-primary: #1a1a2e;
      --color-secondary: #16213e;
      --color-accent: #0f3460;
      --color-bg: #fafafa;
      --color-text: #2d2d2d;
      --color-text-muted: #6b7280;
      --color-border: #e5e7eb;
      --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      --max-width: 720px;
    }
    body {
      font-family: var(--font-sans);
      background: var(--color-bg);
      color: var(--color-text);
      line-height: 1.7;
      font-size: 16px;
    }
    .container {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 80px 24px;
    }
    .hero {
      margin-bottom: 64px;
    }
    .hero h1 {
      font-size: 2.5rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: var(--color-primary);
      margin-bottom: 8px;
    }
    .hero .headline {
      font-size: 1.15rem;
      color: var(--color-text-muted);
      font-weight: 400;
    }
    section {
      margin-bottom: 56px;
    }
    section h2 {
      font-size: 0.8rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--color-text-muted);
      margin-bottom: 20px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--color-border);
    }
    .bio p {
      color: var(--color-text);
      margin-bottom: 16px;
    }
    .experience-item {
      margin-bottom: 32px;
    }
    .experience-item h3 {
      font-size: 1.05rem;
      font-weight: 600;
      color: var(--color-primary);
    }
    .experience-item .meta {
      font-size: 0.9rem;
      color: var(--color-text-muted);
      margin-bottom: 8px;
    }
    .experience-item p {
      font-size: 0.95rem;
      color: var(--color-text);
    }
    .education-item {
      margin-bottom: 20px;
    }
    .education-item h3 {
      font-size: 1rem;
      font-weight: 600;
      color: var(--color-primary);
    }
    .education-item .meta {
      font-size: 0.9rem;
      color: var(--color-text-muted);
    }
    .skills-list {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      list-style: none;
    }
    .skill-badge {
      display: inline-block;
      padding: 4px 14px;
      background: #f3f4f6;
      color: var(--color-text);
      border-radius: 100px;
      font-size: 0.85rem;
      font-weight: 500;
    }
    .project-item {
      margin-bottom: 28px;
    }
    .project-item h3 {
      font-size: 1.05rem;
      font-weight: 600;
      color: var(--color-primary);
    }
    .project-item p {
      font-size: 0.95rem;
      color: var(--color-text);
      margin-bottom: 6px;
    }
    .project-item .tech {
      font-size: 0.8rem;
      color: var(--color-text-muted);
    }
    .project-item a {
      color: var(--color-accent);
      text-decoration: none;
      font-size: 0.9rem;
    }
    .project-item a:hover {
      text-decoration: underline;
    }
    .links-list {
      list-style: none;
      display: flex;
      gap: 24px;
    }
    .links-list a {
      color: var(--color-accent);
      text-decoration: none;
      font-weight: 500;
      font-size: 0.95rem;
    }
    .links-list a:hover {
      text-decoration: underline;
    }
    @media (max-width: 640px) {
      .container { padding: 48px 20px; }
      .hero h1 { font-size: 1.8rem; }
    }
  </style>
</head>
<body>
  <div class="container">
    <header class="hero">
      <h1>{{name}}</h1>
      <p class="headline">{{headline}}</p>
    </header>

    <section class="bio">
      <h2>About</h2>
      <p>{{bio}}</p>
    </section>

    {{#if experience.length}}
    <section>
      <h2>Experience</h2>
      {{#each experience}}
      <div class="experience-item">
        <h3>{{this.title}}</h3>
        <div class="meta">{{this.company}} &middot; {{formatDate this.startDate}} &ndash; {{formatDate this.endDate}}</div>
        <p>{{this.description}}</p>
      </div>
      {{/each}}
    </section>
    {{/if}}

    {{#if education.length}}
    <section>
      <h2>Education</h2>
      {{#each education}}
      <div class="education-item">
        <h3>{{this.institution}}</h3>
        <div class="meta">{{this.degree}} in {{this.field}} &middot; {{formatDate this.graduationDate}}</div>
      </div>
      {{/each}}
    </section>
    {{/if}}

    {{#if skills.length}}
    <section>
      <h2>Skills</h2>
      <div class="skills-list">
        {{#each skills}}
        {{{skillBadge this}}}
        {{/each}}
      </div>
    </section>
    {{/if}}

    {{#if projects.length}}
    <section>
      <h2>Projects</h2>
      {{#each projects}}
      <div class="project-item">
        <h3>{{this.name}}</h3>
        <p>{{this.description}}</p>
        <div class="tech">{{#each this.technologies}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</div>
        {{#if this.url}}
        <a href="{{this.url}}" target="_blank" rel="noopener noreferrer">View project</a>
        {{/if}}
      </div>
      {{/each}}
    </section>
    {{/if}}

    {{#if links.length}}
    <section>
      <h2>Links</h2>
      <ul class="links-list">
        {{#each links}}
        <li>{{{externalLink this.url this.label}}}</li>
        {{/each}}
      </ul>
    </section>
    {{/if}}
  </div>
</body>
</html>
